{
    "name": "tryhackx/flarum-homepage-blocks",
    "description": "Customizable homepage blocks for TryHackX - random movies, tracker stats, advanced filters",
    "keywords": [
        "flarum",
        "flarum-extension",
        "tracker",
        "statistics",
        "opentracker",
        "recaptcha",
        "antispam",
        "validation",
        "title-length",
        "content-length",
        "search",
        "filtering",
        "sorting",
        "widgets",
        "homepage",
        "blocks"
    ],
    "type": "flarum-extension",
    "license": "MIT",
    "authors": [
        {
            "name": "TryHackX",
            "email": "contact@tryhackx.org"
        }
    ],
    "support": {
        "issues": "https://github.com/TryHackX/flarum-homepage-blocks/issues",
        "source": "https://github.com/TryHackX/flarum-homepage-blocks"
    },
    "require": {
        "php": "^8.2",
        "flarum/core": "^1.0.0",
        "flarum/tags": "*"
    },
    "suggest": {
        "fof/discussion-views": "For view count stats",
        "tryhackx/flarum-topic-rating": "For rating-based filtering and sorting",
        "tryhackx/flarum-magnet-link": "For magnet link stats"
    },
    "autoload": {
        "psr-4": {
            "TryHackX\\HomepageBlocks\\": "src/"
        }
    },
    "extra": {
        "flarum-extension": {
            "title": "TryHackX Homepage Blocks",
            "category": "feature",
            "icon": {
                "name": "fas fa-home",
                "color": "#e74c3c",
                "backgroundColor": "#1a1a2e"
            }
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}